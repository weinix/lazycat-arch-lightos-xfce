{
  "permissions": {
    "allow": [
      "Bash(git config *)",
      "Bash(echo \"name: $\\(git config --global user.name\\)\")",
      "Bash(echo \"email: $\\(git config --global user.email\\)\")",
      "Bash(ssh -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10 -T git@github.com)"
    ]
  }
}
